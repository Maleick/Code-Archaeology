{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "code-archaeology/expedition-report",
  "title": "Expedition Report",
  "description": "Schema for individual expedition reports generated by Code Archaeology",
  "type": "object",
  "required": ["phase", "name", "findings", "generated_at"],
  "properties": {
    "phase": {
      "type": "string",
      "enum": [
        "survey",
        "dead_code",
        "legacy",
        "dependencies",
        "types_consolidate",
        "types_harden",
        "dry",
        "errors",
        "polish",
        "final_verify"
      ],
      "description": "Expedition phase identifier"
    },
    "name": {
      "type": "string",
      "description": "Human-readable phase name"
    },
    "findings": {
      "type": "array",
      "description": "Artifacts detected in this expedition",
      "items": {
        "type": "object",
        "required": ["id", "file", "line", "type", "description", "confidence"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique finding identifier"
          },
          "file": {
            "type": "string",
            "description": "File path relative to repo root"
          },
          "line": {
            "type": "integer",
            "description": "Line number (1-indexed)"
          },
          "column": {
            "type": "integer",
            "description": "Column number (1-indexed)"
          },
          "type": {
            "type": "string",
            "description": "Type of artifact found"
          },
          "description": {
            "type": "string",
            "description": "Human-readable description"
          },
          "confidence": {
            "type": "string",
            "enum": ["HIGH", "MEDIUM", "LOW"],
            "description": "Confidence level"
          },
          "recommendation": {
            "type": "string",
            "description": "Recommended action"
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "properties": {
        "total_findings": {
          "type": "integer"
        },
        "high_confidence": {
          "type": "integer"
        },
        "medium_confidence": {
          "type": "integer"
        },
        "low_confidence": {
          "type": "integer"
        },
        "estimated_loc_impact": {
          "type": "integer",
          "description": "Estimated lines of code affected"
        }
      }
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp"
    }
  }
}
